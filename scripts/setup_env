#!/bin/zsh
# Setup environment for learning-api scripts
# Usage: source "$(dirname "$0")/setup_env"

SCRIPT_DIR="$(cd "$(dirname "${(%):-%N}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
API_DIR="$PROJECT_ROOT/apps/api"

echo "Setting up environment for learning-api"
cd "$PROJECT_ROOT"

# Activate a virtual environment when one exists
if [[ -f "$API_DIR/.venv/bin/activate" ]]; then
    source "$API_DIR/.venv/bin/activate"
elif [[ -f "$PROJECT_ROOT/.venv/bin/activate" ]]; then
    source "$PROJECT_ROOT/.venv/bin/activate"
fi

# Load environment variables from .env
if [[ -f "$API_DIR/.env" ]]; then
    export $(grep -v '^#' "$API_DIR/.env" | xargs)
fi

export PYTHONPATH="$API_DIR"

#!/bin/bash

# Check status of Learning API services
# This script checks if services are running

set -e

BACKEND_SESSION="learning-backend"
FRONTEND_SESSION="learning-frontend"

echo "🔍 Checking Learning API services..."
echo ""

# Check tmux sessions
if tmux has-session -t $BACKEND_SESSION 2>/dev/null; then
    echo "✅ Backend tmux session '$BACKEND_SESSION' is running"
else
    echo "❌ Backend tmux session '$BACKEND_SESSION' is not running"
fi

if tmux has-session -t $FRONTEND_SESSION 2>/dev/null; then
    echo "✅ Frontend tmux session '$FRONTEND_SESSION' is running"
else
    echo "❌ Frontend tmux session '$FRONTEND_SESSION' is not running"
fi

echo ""

# Check backend
if curl -s http://localhost:8003/health > /dev/null 2>&1; then
    echo "✅ Backend is running on http://localhost:8003"
else
    echo "❌ Backend is not responding on http://localhost:8003"
fi

# Check frontend
if curl -s http://localhost:5176 > /dev/null 2>&1; then
    echo "✅ Frontend is running on http://localhost:5176"
else
    echo "❌ Frontend is not responding on http://localhost:5176"
fi

echo ""

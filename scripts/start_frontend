#!/bin/zsh

# Start Learning API Frontend
# Usage: ./start_frontend [--tmux]
#   --tmux: Run in a detached tmux session

set -e

SCRIPT_DIR="$(dirname "$0")"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
WEB_DIR="$PROJECT_DIR/apps/web"
SESSION_NAME="learning-frontend"

if [[ "$1" == "--tmux" ]]; then
  # Keep existing healthy session rather than replacing it.
  if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    echo "✅ Frontend tmux session already running: $SESSION_NAME"
    echo "   Frontend: http://localhost:5176"
    echo ""
    echo "   Attach: tmux attach -t $SESSION_NAME"
    exit 0
  fi

  # Create new detached session and auto-restart on unexpected exit.
  tmux new-session -d -s $SESSION_NAME -c "$WEB_DIR"
  tmux send-keys -t $SESSION_NAME "while true; do npm run dev; code=\$?; echo \"[learning-frontend] exited \$code at \$(date). Restarting in 2s...\"; sleep 2; done" Enter
  
  echo "✅ Started frontend in tmux session: $SESSION_NAME"
  echo "   Frontend: http://localhost:5176"
  echo ""
  echo "   Attach: tmux attach -t $SESSION_NAME"
else
  echo "🚀 Starting Learning API Frontend..."
  echo "Frontend will be available at: http://localhost:5176"
  echo ""
  
  cd "$WEB_DIR"
  npm run dev
fi
